{
  "name": "net-energizer",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "main.cjs",
  "author": "Mohamed Elshenawy",
  "description": "Network Energy Analyzer",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on tcp:5173 && electron . --dev\"",
    "build": "vite build",
    "clean": "rimraf release dist",
    "electron:build": "npm run clean && vite build && electron-builder",
    "electron:publish": "npm run clean && vite build && electron-builder --publish always",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "exceljs": "^4.4.0",
    "firebase": "^12.12.0",
    "framer-motion": "^12.38.0",
    "globals": "^17.4.0",
    "lucide-react": "^1.8.0",
    "postcss": "^8.5.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1",
    "rimraf": "^5.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19",
    "tesseract.js": "^7.0.0",
    "vite": "^5.4.21",
    "wait-on": "^9.0.5",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.net.energizer",
    "productName": "NET Energizer",
    "compression": "maximum",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "src/assets/hero.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "files": [
      "dist/**/*",
      "main.cjs"
    ],
    "publish": {
      "provider": "github",
      "owner": "mo7amedmoh",
      "repo": "Energy-Validator"
    }
  }
}
